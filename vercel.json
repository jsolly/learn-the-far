{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "npm run build",
	"outputDirectory": "dist",
	"redirects": [
		{
			"source": "/:path(.*)",
			"has": [{ "type": "host", "value": "www.learnthefar.com" }],
			"destination": "https://learnthefar.com/:path",
			"permanent": true
		}
	]
}
